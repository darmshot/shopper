APP_NAME=Shopper
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Setup for sail cli
APP_SERVICE=app
APP_PORT=8000

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Run modes
RUN_APP_COMMAND_OCTANE_HTTPS_WATCH_MODE="/usr/bin/php -d variables_order=EGPCS /var/www/html/artisan octane:start --host=0.0.0.0 --https --watch"
RUN_APP_COMMAND_OCTANE_HTTP_WATCH_MODE="php -d variables_order=EGPCS /var/www/html/artisan octane:start --host=0.0.0.0 --watch"
RUN_APP_COMMAND_OCTANE_HTTP_MODE="php -d variables_order=EGPCS /var/www/html/artisan octane:start --host=0.0.0.0"
RUN_APP_COMMAND_INSTALL_MIGRATE_OCTANE_HTTP_MODE="composer install --no-dev --optimize-autoloader && php artisan migrate --force && ${RUN_APP_COMMAND_OCTANE_HTTP_MODE}"
RUN_APP_COMMAND_SERVE_MODE="php -d variables_order=EGPCS /var/www/html/artisan serve --host=0.0.0.0"

# Run application
RUN_APP_COMMAND="${RUN_APP_COMMAND_SERVE_MODE}"

# develop,debug,coverag|off
SAIL_XDEBUG_MODE=off

# Which docker-compose file to use in sail commands
COMPOSE_FILE=local.compose.yaml

OCTANE_SERVER=swoole
# true|false
OCTANE_HTTPS=false
OCTANE_WORKERS=16

WWWGROUP=1000
WWWUSER=1000

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

FORWARD_DB_PORT=3306
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=shopper
DB_USERNAME=admin
DB_PASSWORD=password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
